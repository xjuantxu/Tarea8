<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<AnchorPane prefHeight="684.0" prefWidth="746.0" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="biblioteca.vista.controllers.UsuariosController">
    <children>
        <MenuBar fx:id="btnVolver">
            <menus>
                <Menu mnemonicParsing="false" text="Archivo">
                    <items>
                        <MenuItem fx:id="menuVolver" mnemonicParsing="false" text="Volver" onAction="#onVolverClick" />
                    </items>
                </Menu>
                <Menu mnemonicParsing="false" text="Editar">
                    <items>
                        <MenuItem fx:id="menuEditar" mnemonicParsing="false" onAction="#onEditarClick" text="Editar..." />
                        <MenuItem fx:id="menuEliminar" mnemonicParsing="false" onAction="#onEliminarClick" text="Eliminar" />
                    </items>
                </Menu>
                <Menu mnemonicParsing="false" text="Ayuda">
                    <items>
                        <MenuItem mnemonicParsing="false" text="Acerca de" onAction="#AcercaDeShow"/>
                    </items>
                </Menu>
            </menus>
        </MenuBar>
        <VBox alignment="CENTER" layoutY="25.0" prefHeight="79.0" prefWidth="746.0" style="-fx-background-color: #FF7E63;">
            <children>
                <Label alignment="CENTER" style="-fx-text-fill: white; -fx-font-size: 28; -fx-font-weight: bold;" text="Listado de Usuarios" textAlignment="CENTER" />
            </children></VBox>
        <TableView fx:id="tablaUsuarios" layoutX="45.0" layoutY="207.0" prefHeight="392.0" prefWidth="657.0">
            <contextMenu>
                <ContextMenu>
                    <items>
                        <MenuItem fx:id="cxtEditar" mnemonicParsing="false" onAction="#onEditarClick" text="Editar" />
                        <MenuItem fx:id="cxtEliminar" mnemonicParsing="false" onAction="#onEliminarClick" text="Eliminar" />
                    </items>
                </ContextMenu>
            </contextMenu>
            <columns>
                <TableColumn fx:id="colID" prefWidth="75.0" text="DNI" />
                <TableColumn fx:id="colNombre" prefWidth="75.0" text="Nombre" />
                <TableColumn fx:id="colEmail" prefWidth="75.0" text="Email" />
                <TableColumn fx:id="colVia" prefWidth="75.0" text="Via" />
                <TableColumn fx:id="colNumero" prefWidth="75.0" text="Numero" />
                <TableColumn fx:id="colCP" prefWidth="75.0" text="Codigo Postal" />
                <TableColumn fx:id="colLocalidad" prefWidth="105.0" text="Localidad" />
            </columns>
            <columnResizePolicy>
                <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
            </columnResizePolicy>
        </TableView>
        <Button fx:id="btnNuevo" layoutX="45.0" layoutY="618.0" mnemonicParsing="false" onAction="#onNuevoClick" prefHeight="40.0" prefWidth="96.0" text="Nuevo Usuario" />
        <Button layoutX="606.0" layoutY="618.0" mnemonicParsing="false" onAction="#onVolverClick" prefHeight="40.0" prefWidth="96.0" text="Volver" />
        <TextField fx:id="txtBuscar" layoutX="478.0" layoutY="144.0" prefHeight="25.0" prefWidth="224.0" promptText="Introduce campo a buscar..." />
        <Label layoutX="434.0" layoutY="148.0" text="Buscar:" />
    </children>
</AnchorPane>
